{
  "manifest_version": 3,
  "name": "Traffic AI - LinkedIn Outreach",
  "version": "1.0.0",
  "description": "Automate LinkedIn connection requests from your Traffic AI campaigns",
  "permissions": [
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.trafficai.io/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
