{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/fetch-visitors",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/push-klaviyo-events",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/linkedin-drip",
      "schedule": "*/30 * * * *"
    }
  ]
}
